---
/**
 * BuildLogCard — used on the home page and build log index.
 */
interface Props {
  slug: string;
  title: string;
  date: string | null;
  phase: string;
  vehicle: string;
  status: string;
  summary: string;
  coverImage?: string | null;
  featured?: boolean;
}

const { slug, title, date, phase, vehicle, status, summary, coverImage, featured = false } = Astro.props;

// Format the date for display
const displayDate = date
  ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

// Map vehicle value to a readable label
const vehicleLabel = vehicle === '1962-renault-dauphine' ? '1962 Renault Dauphine' : vehicle;

// Map phase value to readable label
const phaseLabel = phase
  .split('-')
  .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
  .join(' ');
---

<a href={`${import.meta.env.BASE_URL}build-log/${slug}`} class={featured ? 'card card--featured' : 'card'}>
  {coverImage && (
    <div class="card__image-wrap">
      <img src={coverImage} alt={title} class="card__image" loading="lazy" />
    </div>
  )}
  {!coverImage && (
    <div class="card__image-wrap card__image-wrap--placeholder">
      <span class="card__image-placeholder-icon">🔧</span>
    </div>
  )}
  <div class="card__body">
    <div class="card__meta">
      <span class={`badge badge--status-${status}`}>{status.replace('-', ' ')}</span>
      <span class="badge badge--phase">{phaseLabel}</span>
    </div>
    <h3 class="card__title">{title}</h3>
    {displayDate && <p class="card__date">{displayDate}</p>}
    <p class="card__vehicle">{vehicleLabel}</p>
    <p class="card__summary">{summary}</p>
    <span class="card__cta">Read more →</span>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.15s;
  }

  .card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .card__image-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface-raised);
  }

  .card__image-wrap--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card__image-placeholder-icon {
    font-size: 2.5rem;
    opacity: 0.3;
  }

  .card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .card:hover .card__image {
    transform: scale(1.03);
  }

  .card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .card__meta {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.25rem;
  }

  .card__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 0.1rem;
  }

  .card__date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .card__vehicle {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .card__summary {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    margin-top: 0.25rem;
    flex: 1;

    /* Clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.5rem;
  }

  /* Featured / full-width variant */
  .card--featured {
    flex-direction: row;
    min-height: 320px;
  }

  .card--featured .card__image-wrap {
    flex: 0 0 50%;
    aspect-ratio: unset;
  }

  .card--featured .card__body {
    padding: 2rem;
    justify-content: center;
    gap: 0.6rem;
  }

  .card--featured .card__title {
    font-size: 1.6rem;
    line-height: 1.25;
  }

  .card--featured .card__summary {
    -webkit-line-clamp: 4;
    font-size: 1rem;
  }

  .card--featured .card__cta {
    font-size: 0.95rem;
    margin-top: 1rem;
  }

  @media (max-width: 700px) {
    .card--featured {
      flex-direction: column;
    }

    .card--featured .card__image-wrap {
      flex: unset;
      aspect-ratio: 16 / 9;
    }
  }
</style>
