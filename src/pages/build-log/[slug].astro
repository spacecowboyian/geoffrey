---
import Layout from '../../layouts/Layout.astro';
import MetaDisplay from '../../components/MetaDisplay.astro';
import Gallery from '../../components/Gallery.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';
import { renderDocument } from '../../utils/renderDocument';

export async function getStaticPaths() {
  const reader = createReader(process.cwd(), keystaticConfig);
  const slugs = await reader.collections.buildLogs.list();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const reader = createReader(process.cwd(), keystaticConfig);
const settings = await reader.singletons.siteSettings.read();

const entry = await reader.collections.buildLogs.read(slug as string, {
  resolveLinkedFiles: true,
});

if (!entry) {
  return Astro.redirect('/build-log');
}

// entry.content is now DocumentElement[] (resolved, not a function)
const contentHtml = renderDocument(entry.content as any);

const displayDate = entry.date
  ? new Date(entry.date).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<Layout
  title={`${entry.title} — ${settings?.siteTitle ?? 'Geoffrey'}`}
  description={entry.summary}
>
  <article class="section">
    <div class="container">
      <!-- Back link -->
      <a href="/build-log" class="back-link">← Build Log</a>

      <!-- Cover image -->
      {entry.coverImage && (
        <div class="cover-image">
          <img src={entry.coverImage} alt={entry.title} />
        </div>
      )}

      <!-- Title block -->
      <header class="entry-header">
        <h1 class="entry-header__title">{entry.title}</h1>
        {displayDate && <p class="entry-header__date">{displayDate}</p>}
        <p class="entry-header__summary">{entry.summary}</p>
      </header>

      <!-- Metadata -->
      <div class="entry-meta">
        <MetaDisplay
          vehicle={entry.vehicle}
          phase={entry.phase}
          status={entry.status}
          date={entry.date}
          odometer={entry.odometer}
          hours={entry.hours}
          partsUsed={entry.partsUsed}
        />
      </div>

      <!-- Gallery (if photos exist) -->
      <Gallery images={entry.gallery} alt={entry.title} />

      <!-- Main content -->
      {contentHtml && (
        <div class="entry-content prose" set:html={contentHtml} />
      )}
    </div>
  </article>
</Layout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .cover-image {
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid var(--color-border);
    max-height: 480px;
  }

  .cover-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .entry-header {
    margin-bottom: 1.75rem;
  }

  .entry-header__title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 0.4rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .entry-header__date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .entry-header__summary {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 65ch;
    line-height: 1.6;
  }

  .entry-meta {
    margin-bottom: 2rem;
  }

  .entry-content {
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-border);
  }
</style>
