---
import Layout from '../../layouts/Layout.astro';
import BuildLogCard from '../../components/BuildLogCard.astro';
import { getAllBuildLogs, getSiteSettings } from '../../utils/queries';
import { urlFor } from '../../utils/imageUrl';

const settings = await getSiteSettings();
const sortedLogs = await getAllBuildLogs();
---

<Layout
  title={`Build Log — ${settings?.siteTitle ?? 'Geoffrey'}`}
  description="All build log entries for the 1962 Renault Dauphine restoration."
>
  <section class="section">
    <div class="container">
      <div class="page-header">
        <h1 class="page-header__title">Build Log</h1>
        <p class="page-header__sub">
          {sortedLogs.length} {sortedLogs.length === 1 ? 'entry' : 'entries'} — newest first
        </p>
      </div>

      {sortedLogs.length === 0 && (
        <p class="empty-state">No build log entries yet.</p>
      )}

      <div class="card-grid">
        {sortedLogs.map((log) => (
          <BuildLogCard
            slug={log.slug}
            title={log.title}
            date={log.date}
            phase={log.phase}
            vehicle={log.vehicle}
            status={log.status}
            summary={log.summary}
            coverImage={log.coverImage ? urlFor(log.coverImage).width(800).auto('format').url() : null}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-header__title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .page-header__sub {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: 2rem;
  }

  @media (max-width: 640px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
